# API keys for chatbot demos
# Copy this file to .env and fill in your keys.
#
# IMPORTANT: Never commit .env files with real keys.
# The .env file is already in .gitignore.

# Anthropic (Claude)
# 1. Create an account at https://console.anthropic.com
# 2. Go to Settings > API Keys
# 3. Click "Create Key" and copy the value
# 4. Paste it below (replacing "your-key-here")
# Note: Anthropic requires a credit card, even for the free tier.
ANTHROPIC_API_KEY=your-key-here

# HuggingFace
# 1. Create an account at https://huggingface.co
# 2. Go to Settings > Access Tokens
# 3. Click "New token", select "Read" scope, and copy the value
# 4. Paste it below (replacing "your-token-here")
# Note: A token enables faster downloads and access to gated models.
HF_TOKEN=your-token-here

# GPT server (llama.cpp)
# Connection details for the llama.cpp server hosting GPT-OSS-20B.
# If you are running the server locally, you don't need these.
# To connect to the shared class server, ask your instructor for
# the URL and API key and paste them below.
PERDRIZET_URL=
PERDRIZET_API_KEY=
